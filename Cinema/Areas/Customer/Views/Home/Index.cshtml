@model IEnumerable<Movie>

@{
    var featured = Model.FirstOrDefault();
    var movies = Model.Skip(1);
}

<div class="container py-4">

    @if (featured != null)
    {
        <div class="card border-0 shadow-lg mb-5 text-white">

            <img src="~/images/Movies/@featured.MainImg"
                 class="card-img"
                 style="height:550px;object-fit:cover;" />

            <div class="card-img-overlay d-flex align-items-end">

                <div class="bg-dark bg-opacity-75 rounded-4 p-4 w-100">

                    <div class="row align-items-center">

                        <div class="col-md-8">

                            <h1 class="display-4 fw-bold">
                                @featured.Name
                            </h1>

                            <div class="mb-3">

                                @{
                                    int featuredStars =
                                    (int)Math.Round(featured.Rating);
                                }

                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= featuredStars)
                                    {
                                        <i class="fas fa-star text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star text-warning"></i>
                                    }
                                }

                                <span class="ms-2 fs-5">
                                    @featured.Rating / 5
                                </span>

                            </div>

                            <a href="/Customer/Home/Details/@featured.Id"
                               class="btn btn-danger btn-lg">
                                View Details
                            </a>

                        </div>

                        <div class="col-md-4 text-md-end">

                            <span class="badge bg-danger fs-3 px-4 py-3">
                                $@featured.Price
                            </span>

                        </div>

                    </div>

                </div>

            </div>

        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            🎬 Latest Movies
        </h2>

        <span class="badge bg-dark">
            @Model.Count() Movies
        </span>

    </div>

    <div class="row g-4">

        @foreach (var movie in movies)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">

                <div class="card border-0 shadow h-100">

                    <img src="~/images/Movies/@movie.MainImg"
                         class="card-img-top"
                         style="height:420px;object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="fw-bold">
                            @movie.Name
                        </h5>

                        <div class="mb-3">

                            @{
                                int stars =
                                (int)Math.Round(movie.Rating);
                            }

                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= stars)
                                {
                                    <i class="fas fa-star text-warning"></i>
                                }
                                else
                                {
                                    <i class="far fa-star text-secondary"></i>
                                }
                            }

                            <span class="ms-2 fw-semibold">
                                @movie.Rating / 5
                            </span>

                        </div>

                        <div class="mt-auto d-flex justify-content-between align-items-center">

                            <span class="badge bg-danger fs-6">
                                $@movie.Price
                            </span>

                            <a asp-action="Details"
                               asp-route-id="@movie.Id"
                               class="btn btn-dark">
                                Details
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>