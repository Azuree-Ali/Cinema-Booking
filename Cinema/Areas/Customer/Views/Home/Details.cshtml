@model Movie

<div class="container py-5">

    <div class="card border-0 shadow-lg">

        <div class="row g-0">

            <div class="col-lg-4">

                <img src="~/images/Movies/@Model.MainImg"
                     class="img-fluid w-100 h-100"
                     style="object-fit:cover;" />

            </div>

            <div class="col-lg-8">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <h1 class="fw-bold">
                                @Model.Name
                            </h1>

                            <p class="text-muted">
                                @Model.Category?.Name
                            </p>

                        </div>

                        <span class="badge bg-danger fs-5">
                            $@Model.Price
                        </span>

                    </div>

                    <hr />

                    <div class="mb-3">

                        @{
                            int stars = (int)Math.Round(Model.Rating);
                        }

                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= stars)
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                            else
                            {
                                <i class="far fa-star text-warning"></i>
                            }
                        }

                        <span class="ms-2 fw-bold">
                            @Model.Rating / 5
                        </span>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <strong>Cinema:</strong>
                            @Model.Cinema?.Name
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Release Date:</strong>
                            @Model.DateTime.ToShortDateString()
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Status:</strong>

                            @if (Model.Status)
                            {
                                <span class="badge bg-success">
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Coming Soon
                                </span>
                            }
                        </div>

                    </div>

                    <div class="mt-4">

                        <h4>Description</h4>

                        <p class="text-muted">
                            @Model.Description
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

    @if (Model.Actors.Any())
    {
        <div class="mt-5">

            <h2 class="fw-bold mb-4">
                🎭 Cast
            </h2>

            <div class="row g-4">

                @foreach (var actor in Model.Actors)
                {
                    <div class="col-lg-2 col-md-3 col-sm-4">

                        <div class="card border-0 shadow-sm h-100">

                            <img src="~/images/Actors/@actor.Img"
                                 class="card-img-top"
                                 style="height:250px;object-fit:cover;" />

                            <div class="card-body text-center">

                                <h6 class="fw-bold mb-1">
                                    @actor.Name
                                </h6>

                                <small class="text-muted">
                                    @actor.Gender
                                </small>

                            </div>

                        </div>

                    </div>
                }

            </div>

        </div>
    }

    @if (Model.SubImages.Any())
    {
        <div class="mt-5">

            <h2 class="fw-bold mb-4">
                📸 Gallery
            </h2>

            <div class="row g-3">

                @foreach (var image in Model.SubImages)
                {
                    <div class="col-lg-3 col-md-4">

                        <img src="~/images/Movies/Movie_SubImages/@image.Img"
                             class="img-fluid rounded shadow-sm w-100"
                             style="height:220px;object-fit:cover;" />

                    </div>
                }

            </div>

        </div>
    }

</div>