@using Cinema.Services
@model ActorVM 

<div class="row gx-3">

    <div class="col-12">

        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

            <div>

                <h3 class="mb-1 fw-bold text-dark">
                    Actors
                </h3>

                <p class="text-600 mb-0 fs--1">
                    Manage all actor categories from one place
                </p>

            </div>

            <a asp-action="Create"
               class="btn btn-primary px-4">

                <i class="fas fa-plus me-2"></i>
                New Actor

            </a>

        </div>

        <!-- Card -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden"
             id="allContactTable">

            <!-- Card Header -->
            <div class="card-header bg-light border-bottom py-3 px-4">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <div>

                        <h5 class="mb-1 fw-semibold">
                            All Actors
                        </h5>

                        <p class="text-600 fs--1 mb-0">
                            Total Actors :
                            <span class="fw-bold text-dark">
                                @Model.Actors.Count()
                            </span>
                        </p>

                    </div>

                    <!-- Search -->
                    <form asp-action="Index"
                          method="get">

                        <div class="input-group input-search-width">

                            <input name="actorName"
                                   value="@ViewBag.ActorName"
                                   class="form-control form-control-sm shadow-none"
                                   type="search"
                                   placeholder="Search actor...">

                            <button class="btn btn-primary btn-sm"
                                    type="submit">

                                <i class="fas fa-search"></i>

                            </button>

                        </div>

                    </form>

                </div>

            </div>

            <!-- Table -->
            <div class="card-body p-0">

                <div class="table-responsive scrollbar">

                    <table class="table align-middle mb-0">

                        <!-- Head -->
                        <thead class="bg-100 text-800">

                            <tr>

                                <th class="ps-4 py-3">
                                    #
                                </th>

                                <th class="py-3">
                                    Actor Name
                                </th>

                                <th class="py-3">
                                    Gender
                                </th>

                                <th class="text-end pe-4 py-3">
                                    Actions
                                </th>

                            </tr>

                        </thead>

                        <!-- Body -->
                        <tbody>

                            @if (Model.Actors.Any())
                            {
                                @foreach (var item in Model.Actors)
                                {
                                    <tr>

                                        <!-- Id -->
                                        <td class="ps-4 fw-semibold text-700">
                                            #@item.Id
                                        </td>

                                        <!-- Name -->
                                        <td>

                                            <div class="d-flex align-items-center gap-2">

                                                <div class="avatar avatar-m">

                                                    <div class="avatar-name rounded-circle bg-soft-primary text-primary">
                                                        <span>
                                                            @item.Name.Substring(0, 1).ToUpper()
                                                        </span>
                                                    </div>

                                                </div>

                                                <div>

                                                    <h6 class="mb-0 fw-semibold text-dark">
                                                        @item.Name
                                                    </h6>

                                                </div>

                                            </div>

                                        </td>

                                        <!-- Gender -->
                                        <td class="text-600">

                                          @item.Gender

                                        </td>

                                        <!-- Actions -->
                                        <td class="text-end pe-4">

                                            <div class="d-flex justify-content-end gap-2">

                                                <!-- Edit -->
                                                <a asp-action="Edit"
                                                   asp-route-id="@item.Id"
                                                   class="btn btn-falcon-default btn-sm">

                                                    <i class="fas fa-edit me-1"></i>
                                                    Edit

                                                </a>

                                                <!-- Delete -->
                                                <a asp-action="Delete"
                                                   asp-route-id="@item.Id"
                                                   class="btn btn-falcon-default btn-sm text-danger">

                                                    <i class="fas fa-trash-alt me-1"></i>
                                                    Delete

                                                </a>

                                            </div>

                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>

                                    <td colspan="5"
                                        class="text-center py-5">

                                        <div class="d-flex flex-column align-items-center">

                                            <i class="fas fa-folder-open text-400 mb-3"
                                               style="font-size: 45px;"></i>

                                            <h5 class="text-muted mb-1">
                                                No Actors Found
                                            </h5>

                                            <p class="text-500 fs--1 mb-0">
                                                Try adding a new actor
                                            </p>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

            <!-- Pagination -->
            <div class="card-footer bg-light border-top py-3 px-4">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <!-- Info -->
                    <div class="text-600 fs--1">

                        Showing Page

                        <span class="fw-bold text-dark">
                            @Model.CurrentPage
                        </span>

                        of

                        <span class="fw-bold text-dark">
                            @Model.TotalPages
                        </span>

                    </div>

                    <!-- Pagination -->
                    <nav>

                        <ul class="pagination pagination-sm mb-0 align-items-center">

                            <!-- Previous -->
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">

                                <a asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-actorName="@ViewBag.ActorName"
                                   class="page-link border-0 rounded-circle shadow-none">

                                    <i class="fas fa-chevron-left fs--2"></i>

                                </a>

                            </li>

                            <!-- Pages -->
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item mx-1 @(Model.CurrentPage == i ? "active" : "")">

                                    <a asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-categoryName="@ViewBag.CategoryName"
                                       class="page-link rounded-circle border-0 shadow-none">

                                        @i

                                    </a>

                                </li>
                            }

                            <!-- Next -->
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">

                                <a asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-actorName="@ViewBag.ActorName"
                                   class="page-link border-0 rounded-circle shadow-none">

                                    <i class="fas fa-chevron-right fs--2"></i>

                                </a>

                            </li>

                        </ul>

                    </nav>

                </div>

            </div>

        </div>

    </div>

</div>