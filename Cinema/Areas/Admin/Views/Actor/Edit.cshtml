@model Actor

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

            <!-- Header -->
            <div class="card-header bg-light border-bottom py-4 px-4">

                <div class="d-flex align-items-center gap-3">

                    <div class="avatar avatar-xl">

                        <div class="avatar-name rounded-circle bg-warning-subtle text-warning">

                            <span>
                                <i class="fas fa-edit"></i>
                            </span>

                        </div>

                    </div>

                    <div>

                        <h4 class="mb-1 fw-bold text-dark">
                            Edit Actor
                        </h4>

                        <p class="text-600 mb-0 fs--1">
                            Update Actor information from your actor dashboard
                        </p>

                    </div>

                </div>

            </div>

            <!-- Form -->
            <form method="post" enctype="multipart/form-data">

                <div class="card-body p-4">

                    <!-- Hidden Id -->
                    <input type="hidden"
                           name="Id"
                           value="@Model.Id" />

                    <!-- Name -->
                    <div class="mb-4">

                        <label class="form-label fw-semibold text-700">
                            Actor Name
                        </label>

                        <div class="input-group">

                            <span class="input-group-text bg-light border-end-0">

                                <i class="fas fa-layer-group text-warning"></i>

                            </span>

                            <input type="text"
                                   name="Name"
                                   value="@Model.Name"
                                   class="form-control border-start-0 shadow-none"
                                   placeholder="Enter Actor name">

                        </div>

                    </div>
                    <!-- Gender -->
                    <div class="mb-3">

                        <label class="form-label fw-semibold text-700">
                            Gender
                        </label>

                        <select name="Gender"
                                class="form-select shadow-none">

                            @if (Model.Gender == "Male")
                            {
                                <option value="Male" selected>
                                    Male
                                </option>

                                <option value="Female">
                                    Female
                                </option>
                            }
                            else
                            {
                                <option value="Female" selected>
                                    Female
                                </option>

                                <option value="Male" >
                                    Male
                                </option>
                            }

                        </select>

                    </div>

                </div>
                <!-- Image -->
                <div class="mb-4">

                    <label class="form-label fw-semibold text-700">
                        Actor Image
                    </label>

                    <div class="d-flex align-items-center gap-3">

                        <!-- Preview -->
                        <div class="border rounded-3 overflow-hidden" style="width: 90px; height: 90px;">
                            <img id="imagePreview"
                                 src="https://via.placeholder.com/90"
                                 class="w-100 h-100 object-fit-cover" />
                        </div>

                        <!-- Input -->
                        <div class="flex-grow-1">

                            <input type="file"
                                   name="ImageFile"
                                   class="form-control shadow-none"
                                   accept="image/*"
                                   onchange="previewImage(event)" />

                            <small class="text-muted">
                                Supported formats: jpg, png, jpeg
                            </small>

                        </div>

                    </div>

                </div>

                <!-- Footer -->
                <div class="card-footer bg-light border-top px-4 py-3">

                    <div class="d-flex justify-content-end gap-2">

                        <!-- Back -->
                        <a asp-action="Index"
                           class="btn btn-falcon-default px-4">

                            <i class="fas fa-arrow-left me-2"></i>
                            Back

                        </a>

                        <!-- Save -->
                        <button type="submit"
                                class="btn btn-warning text-white px-4">

                            <i class="fas fa-save me-2"></i>
                            Update Actor

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

</div>
<script>
    function previewImage(event) {
        var input = event.target;
        var reader = new FileReader();

        reader.onload = function () {
            var img = document.getElementById("imagePreview");
            img.src = reader.result;
        };

        if (input.files && input.files[0]) {
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>