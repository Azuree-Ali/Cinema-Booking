<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

            <!-- Header -->
            <div class="card-header bg-light border-bottom py-4 px-4">

                <div class="d-flex align-items-center gap-3">

                    <div class="avatar avatar-xl">
                        <div class="avatar-name rounded-circle bg-primary-subtle text-primary">
                            <span>
                                <i class="fas fa-folder-plus"></i>
                            </span>
                        </div>
                    </div>

                    <div>
                        <h4 class="mb-1 fw-bold text-dark">
                            Create Actor
                        </h4>

                        <p class="text-600 mb-0 fs--1">
                            Add a new actor to your dashboard
                        </p>
                    </div>

                </div>

            </div>

            <!-- Form -->
            <form method="post" enctype="multipart/form-data">

                <div class="card-body p-4">

                    <!-- Name -->
                    <div class="mb-4">

                        <label class="form-label fw-semibold text-700">
                            Actor Name
                        </label>

                        <div class="input-group">

                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-layer-group text-primary"></i>
                            </span>

                            <input type="text"
                                   name="Name"
                                   class="form-control border-start-0 shadow-none"
                                   placeholder="Enter actor name">

                        </div>

                    </div>
                    <!-- Gender -->
                    <div class="mb-4">

                        <label class="form-label fw-semibold text-700">
                            Actor Gender
                        </label>

                        <div class="input-group">

                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-venus-mars text-primary"></i>
                            </span>

                            <select name="Gender"
                                    class="form-select border-start-0 shadow-none">

                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>

                            </select>

                        </div>

                    </div>
                <!-- Image -->
                <div class="mb-4">

                    <label class="form-label fw-semibold text-700">
                        Actor Image
                    </label>

                    <div class="d-flex align-items-center gap-3">

                        <!-- Preview -->
                        <div class="border rounded-3 overflow-hidden" style="width: 90px; height: 90px;">
                            <img id="imagePreview"
                                 src="https://via.placeholder.com/90"
                                 class="w-100 h-100 object-fit-cover" />
                        </div>

                        <!-- Input -->
                        <div class="flex-grow-1">

                            <input type="file"
                                   name="ImageFile"
                                   class="form-control shadow-none"
                                   accept="image/*"
                                   onchange="previewImage(event)" />

                            <small class="text-muted">
                                Supported formats: jpg, png, jpeg
                            </small>

                        </div>

                    </div>

                </div>

                <!-- Footer -->
                <div class="card-footer bg-light border-top px-4 py-3">

                    <div class="d-flex justify-content-end gap-2">

                        <a asp-action="Index"
                           class="btn btn-falcon-default px-4">

                            <i class="fas fa-arrow-left me-2"></i>
                            Back

                        </a>

                        <button type="submit"
                                class="btn btn-primary px-4">

                            <i class="fas fa-save me-2"></i>
                            Save Category

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>
</div>
<script>
    function previewImage(event) {
        var input = event.target;
        var reader = new FileReader();

        reader.onload = function () {
            var img = document.getElementById("imagePreview");
            img.src = reader.result;
        };

        if (input.files && input.files[0]) {
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>