@using Cinema.ViewModels
@model CreateMovieVM

<div class="row justify-content-center">
    <div class="col-lg-10">

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

            <div class="card-header bg-light border-bottom py-4 px-4">

                <div class="d-flex align-items-center gap-3">

                    <div class="avatar avatar-xl">
                        <div class="avatar-name rounded-circle bg-primary-subtle text-primary">
                            <span>
                                <i class="fas fa-film"></i>
                            </span>
                        </div>
                    </div>

                    <div>
                        <h4 class="mb-1 fw-bold">
                            Create Movie
                        </h4>

                        <p class="text-600 mb-0 fs--1">
                            Add a new movie to your cinema system
                        </p>
                    </div>

                </div>

            </div>

            <form method="post" enctype="multipart/form-data">

                <div class="card-body p-4">

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Movie Name
                            </label>

                            <input asp-for="Name"
                                   class="form-control shadow-none">

                            <span asp-validation-for="Name"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Price
                            </label>

                            <input asp-for="Price"
                                   class="form-control shadow-none">

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Release Date
                            </label>

                            <input asp-for="DateTime"
                                   type="datetime-local"
                                   class="form-control shadow-none">

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Rating
                            </label>

                            <input asp-for="Rating"
                                   class="form-control shadow-none">

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Category
                            </label>

                            <select name="CategoryId" class="form-select shadow-none">

                                @foreach (var item in Model.Categories)
                                {
                                    <option value="@item.Id">
                                        @item.Name
                                    </option>
                                }

                            </select>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Cinema
                            </label>

                            <select name="CinemaId" class="form-select shadow-none">

                                @foreach (var item in Model.Cinemas)
                                {
                                    <option value="@item.Id">
                                        @item.Name
                                    </option>
                                }

                            </select>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Status
                            </label>

                            <select asp-for="Status"
                                    class="form-select shadow-none">

                                <option value="true">
                                    Active
                                </option>

                                <option value="false">
                                    Inactive
                                </option>

                            </select>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Main Image
                            </label>

                            <input asp-for="MainImage"
                                   type="file"
                                   class="form-control">

                        </div>

                        <div class="col-12 mb-4">

                            <label class="form-label fw-semibold">
                                Sub Images
                            </label>

                            <input asp-for="SubImages"
                                   type="file"
                                   multiple
                                   class="form-control">

                        </div>

                        <div class="col-12 mb-4">

                            <label class="form-label fw-semibold">
                                Description
                            </label>

                            <textarea asp-for="Description"
                                      rows="5"
                                      class="form-control shadow-none"></textarea>

                        </div>

                    </div>

                </div>

                <div class="card-footer bg-light border-top px-4 py-3">

                    <div class="d-flex justify-content-end gap-2">

                        <a asp-action="Index"
                           class="btn btn-falcon-default">

                            Back

                        </a>

                        <button type="submit"
                                class="btn btn-primary">

                            <i class="fas fa-save me-2"></i>
                            Save Movie

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>
</div>