@using Cinema.ViewModels
@model MovieVM

<div class="row gx-3">
    <div class="col-12">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h4 class="mb-1">Movies</h4>
                <p class="text-600 mb-0 fs--1">
                    Manage all movies
                </p>
            </div>

            <a asp-action="Create"
               class="btn btn-primary">

                <i class="fas fa-plus me-2"></i>
                New Movie

            </a>

        </div>

        <!-- Card -->
        <div class="card shadow-sm border-0">

            <!-- Search -->
            <div class="card-header bg-light">

                <form asp-action="Index"
                      method="get">

                    <div class="input-group">

                        <input type="text"
                               name="movieName"
                               value="@Model.MovieName"
                               class="form-control"
                               placeholder="Search by movie name">

                        <button class="btn btn-primary">

                            <i class="fas fa-search"></i>

                        </button>

                    </div>

                </form>

            </div>

            <!-- Table -->
            <div class="card-body p-0">

                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead class="bg-light">

                            <tr>

                                <th>Poster</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Cinema</th>
                                <th>Price</th>
                                <th>Rating</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model.Movies)
                            {
                                <tr>

                                    <td>

                                        <img src="~/Files/@item.MainImg"
                                             width="60"
                                             height="60"
                                             class="rounded shadow-sm"
                                             style="object-fit:cover;" />

                                    </td>

                                    <td>
                                        @item.Name
                                    </td>

                                    <td>
                                        @item.Category.Name
                                    </td>

                                    <td>
                                        @item.Cinema.Name
                                    </td>

                                    <td>
                                        @item.Price EGP
                                    </td>

                                    <td>
                                        ⭐ @item.Rating
                                    </td>

                                    <td>
                                        @item.DateTime.ToString("dd MMM yyyy")
                                    </td>

                                    <td>

                                        @if (item.Status)
                                        {
                                            <span class="badge badge-soft-success">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-soft-danger">
                                                Inactive
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <div class="d-flex justify-content-end gap-2">

                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-falcon-default btn-sm">

                                                <i class="fas fa-edit"></i>

                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               onclick="return confirm('Are you sure?')"
                                               class="btn btn-falcon-default btn-sm text-danger">

                                                <i class="fas fa-trash"></i>

                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

            <!-- Pagination -->
            <div class="card-footer">

                <nav>

                    <ul class="pagination justify-content-center mb-0">

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">

                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-movieName="@Model.MovieName">

                                    @i

                                </a>

                            </li>
                        }

                    </ul>

                </nav>

            </div>

        </div>

    </div>
</div>